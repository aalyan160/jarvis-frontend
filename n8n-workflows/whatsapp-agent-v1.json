      "id": "ffd78bb7-162a-48fd-8fb7-f483c7aa88b9",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        -320,
        180
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json || {};\nconst reply = String(item.output || item.reply || item.text || 'WhatsApp Agent finished.').trim();\n\nreturn [{\n  json: {\n    success: true,\n    agent: 'whatsapp',\n    action: item.action || 'send_whatsapp_message',\n    status: 'completed',\n    reply,\n    output: reply,\n    raw: item\n  }\n}];\n"
      },
